{
  "operation": "get-workspace",
  "method": "GET",
  "path": "/w/{workspace}/workspaces/get",
  "summary": "Get Workspace Settings",
  "request": {
    "workspace": "my-workspace"
  },
  "response": {
    "id": "my-workspace",
    "name": "My Workspace",
    "owner": "admin@example.com",
    "domain": "example.com"
  }
}